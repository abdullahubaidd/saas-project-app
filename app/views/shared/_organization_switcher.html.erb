<% if user_signed_in? && current_user.organizations.any? %>
  <div class="relative inline-block text-left">
    <div>
      <button type="button" class="inline-flex w-full justify-center gap-x-1.5 rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" id="organization-menu-button" aria-expanded="true" aria-haspopup="true" onclick="toggleOrgMenu()">
        <%= current_organization&.name || "Select Organization" %>
        <svg class="-mr-1 h-5 w-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
        </svg>
      </button>
    </div>

    <div class="absolute right-0 z-10 mt-2 w-56 origin-top-right rounded-md bg-white shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none hidden" role="menu" aria-orientation="vertical" aria-labelledby="organization-menu-button" tabindex="-1" id="organization-menu">
      <div class="py-1" role="none">
        <% current_user.organizations.each do |organization| %>
          <% if organization == current_organization %>
            <div class="text-gray-700 px-4 py-2 text-sm bg-gray-100">
              <%= organization.name %> ✓
            </div>
          <% else %>
            <%= link_to organization.name, switch_organization_path(organization), 
                method: :patch,
                class: "text-gray-700 block px-4 py-2 text-sm hover:bg-gray-100",
                role: "menuitem" %>
          <% end %>
        <% end %>
        
        <hr class="my-1">
        <%= link_to "All Organizations", organizations_path, 
            class: "text-gray-700 block px-4 py-2 text-sm hover:bg-gray-100",
            role: "menuitem" %>
        <%= link_to "Create New Organization", new_organization_path, 
            class: "text-gray-700 block px-4 py-2 text-sm hover:bg-gray-100",
            role: "menuitem" %>
      </div>
    </div>
  </div>

  <script>
    function toggleOrgMenu() {
      const menu = document.getElementById('organization-menu');
      menu.classList.toggle('hidden');
    }
    
    // Close menu when clicking outside
    document.addEventListener('click', function(event) {
      const menu = document.getElementById('organization-menu');
      const button = document.getElementById('organization-menu-button');
      
      if (!menu.contains(event.target) && !button.contains(event.target)) {
        menu.classList.add('hidden');
      }
    });
  </script>
<% end %>
