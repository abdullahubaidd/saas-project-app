<div class="min-h-screen bg-gray-50 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900">Admin Dashboard</h1>
      <p class="mt-2 text-gray-600">Manage tenants and users across all workspaces</p>
    </div>

    <!-- Create New Tenant Form -->
    <div class="bg-white shadow rounded-lg p-6 mb-8">
      <h2 class="text-xl font-semibold mb-4">Create New Tenant</h2>
      <%= form_with model: Tenant.new, url: admin_create_tenant_path, local: true do |form| %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
            <%= form.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500", placeholder: "Company Name" %>
          </div>
          <div>
            <%= form.label :subdomain, class: "block text-sm font-medium text-gray-700" %>
            <%= form.text_field :subdomain, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500", placeholder: "subdomain" %>
          </div>
        </div>
        <div class="mt-4">
          <%= form.submit "Create Tenant", class: "bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2 px-4 rounded" %>
        </div>
      <% end %>
    </div>

    <!-- Tenants List -->
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-xl font-semibold">Existing Tenants</h2>
      </div>
      
      <% if @tenants.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Subdomain</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Users</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @tenants.each do |tenant| %>
                <tr>
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                    <%= tenant.name %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                    <%= tenant.subdomain %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                    <%= tenant.users.count %> users
                    <% if tenant.users.any? %>
                      <div class="text-xs text-gray-400">
                        <%= tenant.users.pluck(:email).join(', ') %>
                      </div>
                    <% end %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                    <a href="http://<%= tenant.subdomain %>.localhost:3000" 
                       target="_blank"
                       class="text-indigo-600 hover:text-indigo-900">
                      Visit Workspace
                    </a>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="px-6 py-8 text-center">
          <p class="text-gray-500">No tenants created yet.</p>
        </div>
      <% end %>
    </div>

    <div class="mt-8 text-center">
      <%= link_to "Back to Main Site", root_path, class: "text-indigo-600 hover:text-indigo-900" %>
    </div>
  </div>
</div>
