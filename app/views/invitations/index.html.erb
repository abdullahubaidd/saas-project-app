<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="md:flex md:items-center md:justify-between mb-8">
    <div class="flex-1 min-w-0">
      <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate">
        Team Invitations
      </h2>
      <p class="mt-1 text-sm text-gray-500">
        Manage invitations for <%= current_organization.name %>
      </p>
    </div>
    <div class="mt-4 flex md:mt-0 md:ml-4">
      <%= link_to "Send Invitation", new_organization_invitation_path(current_organization),
          class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
    </div>
  </div>

  <!-- Pending Invitations -->
  <div class="bg-white shadow overflow-hidden sm:rounded-md mb-8">
    <div class="px-4 py-5 sm:px-6">
      <h3 class="text-lg leading-6 font-medium text-gray-900">
        Pending Invitations
        <span class="ml-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
          <%= @pending_invitations.count %>
        </span>
      </h3>
      <p class="mt-1 max-w-2xl text-sm text-gray-500">
        Invitations waiting for acceptance
      </p>
    </div>
    
    <% if @pending_invitations.any? %>
      <ul role="list" class="divide-y divide-gray-200">
        <% @pending_invitations.each do |invitation| %>
          <li class="px-4 py-4 sm:px-6">
            <div class="flex items-center justify-between">
              <div class="flex items-center">
                <div class="flex-shrink-0">
                  <div class="h-10 w-10 rounded-full bg-gray-300 flex items-center justify-center">
                    <span class="text-sm font-medium text-gray-700">
                      <%= invitation.email.first.upcase %>
                    </span>
                  </div>
                </div>
                <div class="ml-4">
                  <div class="flex items-center">
                    <p class="text-sm font-medium text-gray-900">
                      <%= invitation.email %>
                    </p>
                    <span class="ml-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                      <%= invitation.role.capitalize %>
                    </span>
                  </div>
                  <p class="text-sm text-gray-500">
                    Invited by <%= invitation.invited_by.full_name %> on <%= invitation.created_at.strftime("%B %d, %Y") %>
                  </p>
                  <p class="text-xs text-gray-400">
                    Expires on <%= invitation.expires_at.strftime("%B %d, %Y at %I:%M %p") %>
                  </p>
                </div>
              </div>
              <div class="flex items-center space-x-2">
                <%= link_to "Resend", resend_organization_invitation_path(current_organization, invitation),
                    method: :patch,
                    class: "inline-flex items-center px-3 py-1 border border-gray-300 rounded-md text-xs font-medium text-gray-700 bg-white hover:bg-gray-50" %>
                <%= link_to "Cancel", organization_invitation_path(current_organization, invitation),
                    method: :delete,
                    confirm: "Are you sure you want to cancel this invitation?",
                    class: "inline-flex items-center px-3 py-1 border border-red-300 rounded-md text-xs font-medium text-red-700 bg-white hover:bg-red-50" %>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="px-4 py-5 sm:px-6 text-center">
        <p class="text-gray-500">No pending invitations</p>
      </div>
    <% end %>
  </div>

  <!-- Expired Invitations -->
  <% if @expired_invitations.any? %>
    <div class="bg-white shadow overflow-hidden sm:rounded-md">
      <div class="px-4 py-5 sm:px-6">
        <h3 class="text-lg leading-6 font-medium text-gray-900">
          Expired Invitations
          <span class="ml-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
            <%= @expired_invitations.count %>
          </span>
        </h3>
        <p class="mt-1 max-w-2xl text-sm text-gray-500">
          Invitations that have expired
        </p>
      </div>
      
      <ul role="list" class="divide-y divide-gray-200">
        <% @expired_invitations.each do |invitation| %>
          <li class="px-4 py-4 sm:px-6 opacity-60">
            <div class="flex items-center justify-between">
              <div class="flex items-center">
                <div class="flex-shrink-0">
                  <div class="h-10 w-10 rounded-full bg-gray-300 flex items-center justify-center">
                    <span class="text-sm font-medium text-gray-700">
                      <%= invitation.email.first.upcase %>
                    </span>
                  </div>
                </div>
                <div class="ml-4">
                  <div class="flex items-center">
                    <p class="text-sm font-medium text-gray-900">
                      <%= invitation.email %>
                    </p>
                    <span class="ml-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                      <%= invitation.role.capitalize %>
                    </span>
                    <span class="ml-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                      Expired
                    </span>
                  </div>
                  <p class="text-sm text-gray-500">
                    Invited by <%= invitation.invited_by.full_name %> on <%= invitation.created_at.strftime("%B %d, %Y") %>
                  </p>
                  <p class="text-xs text-gray-400">
                    Expired on <%= invitation.expires_at.strftime("%B %d, %Y at %I:%M %p") %>
                  </p>
                </div>
              </div>
              <div class="flex items-center space-x-2">
                <%= link_to "Remove", organization_invitation_path(current_organization, invitation),
                    method: :delete,
                    confirm: "Are you sure you want to remove this expired invitation?",
                    class: "inline-flex items-center px-3 py-1 border border-gray-300 rounded-md text-xs font-medium text-gray-700 bg-white hover:bg-gray-50" %>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>
