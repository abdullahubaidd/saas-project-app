<!-- Main landing page -->
<div class="min-h-screen bg-gradient-to-br from-blue-50 to-indigo-100">
  <div class="container mx-auto px-4 py-16">
    <div class="text-center">
      <h1 class="text-5xl font-bold text-gray-900 mb-4">Welcome to Your SaaS App</h1>
      <p class="text-xl text-gray-600 mb-8">Manage your organizations and projects in one place</p>
      
      <% unless user_signed_in? %>
        <div class="bg-white rounded-lg shadow-lg p-8 max-w-md mx-auto mb-8">
          <h2 class="text-2xl font-semibold mb-6">Get Started</h2>
          <div class="space-y-4">
            <%= link_to "Sign Up", new_user_registration_path, 
                class: "w-full bg-blue-500 hover:bg-blue-700 text-white font-bold py-3 px-4 rounded block text-center" %>
            <%= link_to "Sign In", new_user_session_path, 
                class: "w-full bg-gray-500 hover:bg-gray-700 text-white font-bold py-3 px-4 rounded block text-center" %>
          </div>
        </div>
      <% end %>

      <div class="max-w-4xl mx-auto">
        <h3 class="text-2xl font-semibold text-gray-800 mb-6">Key Features</h3>
        <div class="grid md:grid-cols-3 gap-6">
          <div class="bg-white rounded-lg shadow-lg p-6">
            <div class="text-blue-500 text-4xl mb-4">🏢</div>
            <h4 class="text-xl font-semibold mb-2">Organizations</h4>
            <p class="text-gray-600">Create and manage multiple organizations with separate workspaces.</p>
          </div>
          
          <div class="bg-white rounded-lg shadow-lg p-6">
            <div class="text-green-500 text-4xl mb-4">📋</div>
            <h4 class="text-xl font-semibold mb-2">Projects</h4>
            <p class="text-gray-600">Organize your work into projects and collaborate with team members.</p>
          </div>
          
          <div class="bg-white rounded-lg shadow-lg p-6">
            <div class="text-purple-500 text-4xl mb-4">👥</div>
            <h4 class="text-xl font-semibold mb-2">Team Collaboration</h4>
            <p class="text-gray-600">Invite team members and manage access to different projects.</p>
          </div>
        </div>
      </div>

      <% if @organizations&.any? %>
        <div class="mt-12 max-w-2xl mx-auto">
          <h3 class="text-xl font-semibold text-gray-800 mb-4">Sample Organizations</h3>
          <div class="bg-white rounded-lg shadow-lg p-6">
            <div class="space-y-2">
              <% @organizations.each do |org| %>
                <div class="flex justify-between items-center p-3 border rounded hover:bg-gray-50">
                  <div>
                    <span class="font-medium"><%= org.name %></span>
                    <% if org.description.present? %>
                      <p class="text-sm text-gray-600"><%= org.description %></p>
                    <% end %>
                  </div>
                  <span class="text-sm text-gray-500"><%= pluralize(org.users.count, 'member') %></span>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
        </div>
      </div>
    </div>
  </div>
</div>
