<% content_for :title, "Add Members to #{@project.name}" %>

<div class="min-h-screen bg-gray-50">
  <div class="max-w-3xl mx-auto py-6 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="md:flex md:items-center md:justify-between mb-8">
      <div class="flex-1 min-w-0">
        <!-- Breadcrumb -->
        <nav class="flex mb-4" aria-label="Breadcrumb">
          <ol class="flex items-center space-x-4">
            <li>
              <%= link_to @organization.name, organization_path(@organization), 
                  class: "text-sm font-medium text-gray-500 hover:text-gray-700" %>
            </li>
            <li>
              <div class="flex items-center">
                <svg class="flex-shrink-0 h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                </svg>
                <%= link_to @project.name, [@organization, @project], 
                    class: "ml-4 text-sm font-medium text-gray-500 hover:text-gray-700" %>
              </div>
            </li>
            <li>
              <div class="flex items-center">
                <svg class="flex-shrink-0 h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                </svg>
                <span class="ml-4 text-sm font-medium text-gray-900">Add Members</span>
              </div>
            </li>
          </ol>
        </nav>

        <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate">
          Add Members to Project
        </h2>
        <p class="mt-1 text-sm text-gray-500">
          Select organization members to add to this project.
        </p>
      </div>
    </div>

    <% if @available_members.any? %>
      <!-- Add Member Form -->
      <div class="bg-white shadow rounded-lg mb-8">
        <div class="px-6 py-4 border-b border-gray-200">
          <h3 class="text-lg font-medium text-gray-900">Select Member</h3>
        </div>
        
        <%= form_with model: [@organization, @project, @project_assignment], local: true, class: "px-6 py-4" do |form| %>
          <% if @project_assignment.errors.any? %>
            <div class="rounded-md bg-red-50 p-4 mb-6">
              <div class="flex">
                <div class="flex-shrink-0">
                  <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                  </svg>
                </div>
                <div class="ml-3">
                  <h3 class="text-sm font-medium text-red-800">
                    <%= pluralize(@project_assignment.errors.count, "error") %> prohibited this assignment from being saved:
                  </h3>
                  <div class="mt-2 text-sm text-red-700">
                    <ul class="list-disc pl-5 space-y-1">
                      <% @project_assignment.errors.full_messages.each do |message| %>
                        <li><%= message %></li>
                      <% end %>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          <% end %>

          <div class="space-y-6">
            <!-- Member Selection -->
            <div>
              <%= form.label :user_id, "Organization Member", class: "block text-sm font-medium text-gray-700" %>
              <div class="mt-1">
                <%= form.select :user_id, 
                    options_from_collection_for_select(@available_members, :id, :email), 
                    { prompt: "Select a member to add..." },
                    { class: "shadow-sm focus:ring-blue-500 focus:border-blue-500 block w-full sm:text-sm border-gray-300 rounded-md", required: true } %>
              </div>
              <p class="mt-2 text-sm text-gray-500">
                Only organization members who are not already part of this project are shown.
              </p>
            </div>

            <!-- Role Selection -->
            <div>
              <%= form.label :role, "Project Role", class: "block text-sm font-medium text-gray-700" %>
              <div class="mt-1">
                <%= form.select :role, 
                    options_for_select([
                      ['Member - Can view and contribute to project', 'member'],
                      ['Admin - Can manage project and members', 'admin'],
                      ['Viewer - Can only view project content', 'viewer']
                    ], 'member'), 
                    {},
                    { class: "shadow-sm focus:ring-blue-500 focus:border-blue-500 block w-full sm:text-sm border-gray-300 rounded-md" } %>
              </div>
              <p class="mt-2 text-sm text-gray-500">
                Choose the level of access this member will have in the project.
              </p>
            </div>
          </div>

          <!-- Form Actions -->
          <div class="pt-6 border-t border-gray-200 mt-6">
            <div class="flex justify-end space-x-3">
              <%= link_to "Cancel", [@organization, @project], 
                  class: "bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
              <%= form.submit "Add Member", 
                  class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <!-- No Available Members -->
      <div class="bg-white shadow rounded-lg">
        <div class="px-6 py-4 border-b border-gray-200">
          <h3 class="text-lg font-medium text-gray-900">No Available Members</h3>
        </div>
        <div class="px-6 py-8 text-center">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 48 48">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5m-2 3v4m-4-7v4m2-4h.01M21 16h.01M17 16h.01M12 20h5m-2 3v4m-4-7v4m2-4h.01M21 12h.01M17 12h.01"/>
          </svg>
          <h3 class="mt-2 text-sm font-medium text-gray-900">All members already added</h3>
          <p class="mt-1 text-sm text-gray-500">
            All organization members are already part of this project, or you need to invite more members to the organization first.
          </p>
          <div class="mt-6 flex justify-center space-x-3">
            <%= link_to "Back to Project", [@organization, @project], 
                class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
            <%= link_to "Invite More Members", new_organization_invitation_path(@organization), 
                class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
