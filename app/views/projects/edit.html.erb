<% content_for :title, "Edit #{@project.name}" %>

<div class="min-h-screen bg-gray-50">
  <div class="max-w-3xl mx-auto py-6 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="md:flex md:items-center md:justify-between mb-8">
      <div class="flex-1 min-w-0">
        <!-- Breadcrumb -->
        <nav class="flex mb-4" aria-label="Breadcrumb">
          <ol class="flex items-center space-x-4">
            <li>
              <%= link_to current_organization.name, organization_path(current_organization), 
                  class: "text-sm font-medium text-gray-500 hover:text-gray-700" %>
            </li>
            <li>
              <div class="flex items-center">
                <svg class="flex-shrink-0 h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                </svg>
                <%= link_to @project.name, [@organization, @project], 
                    class: "ml-4 text-sm font-medium text-gray-500 hover:text-gray-700" %>
              </div>
            </li>
            <li>
              <div class="flex items-center">
                <svg class="flex-shrink-0 h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                </svg>
                <span class="ml-4 text-sm font-medium text-gray-900">Edit</span>
              </div>
            </li>
          </ol>
        </nav>

        <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate">
          Edit Project
        </h2>
        <p class="mt-1 text-sm text-gray-500">
          Update your project details and settings.
        </p>
      </div>
    </div>

    <!-- Form -->
    <div class="bg-white shadow rounded-lg">
      <div class="px-6 py-4 border-b border-gray-200">
        <h3 class="text-lg font-medium text-gray-900">Project Information</h3>
      </div>
      
      <%= form_with model: [@organization, @project], local: true, class: "px-6 py-4" do |form| %>
        <% if @project.errors.any? %>
          <div class="rounded-md bg-red-50 p-4 mb-6">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-red-800">
                  <%= pluralize(@project.errors.count, "error") %> prohibited this project from being updated:
                </h3>
                <div class="mt-2 text-sm text-red-700">
                  <ul class="list-disc pl-5 space-y-1">
                    <% @project.errors.full_messages.each do |message| %>
                      <li><%= message %></li>
                    <% end %>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <div class="space-y-6">
          <!-- Project Name -->
          <div>
            <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.text_field :name, 
                  class: "shadow-sm focus:ring-blue-500 focus:border-blue-500 block w-full sm:text-sm border-gray-300 rounded-md",
                  placeholder: "Enter project name",
                  required: true %>
            </div>
            <p class="mt-2 text-sm text-gray-500">
              Choose a descriptive name for your project.
            </p>
          </div>

          <!-- Project Description -->
          <div>
            <%= form.label :description, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.text_area :description, 
                  rows: 4,
                  class: "shadow-sm focus:ring-blue-500 focus:border-blue-500 block w-full sm:text-sm border-gray-300 rounded-md",
                  placeholder: "Describe what this project is about..." %>
            </div>
            <p class="mt-2 text-sm text-gray-500">
              Provide a brief description of the project's purpose and goals.
            </p>
          </div>

          <!-- Project Status -->
          <div>
            <%= form.label :archived, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <div class="flex items-center">
                <%= form.check_box :archived, class: "focus:ring-blue-500 h-4 w-4 text-blue-600 border-gray-300 rounded" %>
                <%= form.label :archived, "Archive this project", class: "ml-2 block text-sm text-gray-900" %>
              </div>
            </div>
            <p class="mt-2 text-sm text-gray-500">
              Archived projects are read-only and won't appear in the main project list.
            </p>
          </div>
        </div>

        <!-- Form Actions -->
        <div class="pt-6 border-t border-gray-200 mt-6">
          <div class="flex justify-end space-x-3">
            <%= link_to "Cancel", [@organization, @project], 
                class: "bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
            <%= form.submit "Update Project", 
                class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Danger Zone -->
    <% if current_user.admin_of?(current_organization) %>
      <div class="mt-8 bg-white shadow rounded-lg">
        <div class="px-6 py-4 border-b border-gray-200">
          <h3 class="text-lg font-medium text-red-600">Danger Zone</h3>
        </div>
        <div class="px-6 py-4">
          <div class="rounded-md bg-red-50 p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-red-800">
                  Delete Project
                </h3>
                <div class="mt-2 text-sm text-red-700">
                  <p>Once you delete a project, there is no going back. Please be certain.</p>
                </div>
                <div class="mt-4">
                  <%= button_to "Delete this project", [@organization, @project], 
                      method: :delete,
                      data: { 
                        confirm: "Are you sure you want to delete '#{@project.name}'? This action cannot be undone.",
                        turbo_method: :delete
                      },
                      class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-red-700 bg-red-100 hover:bg-red-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
